rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public can READ gallery, testimonials, faq, and contact settings
    match /gallery/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /testimonials/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /faq/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /settings/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /classes/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /registrations/{doc} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
